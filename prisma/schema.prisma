generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                    String @id @default(uuid())
  username              String?    @unique

  email                 String    @unique
  password              String?

  provider              AuthProvider
  emailVerified         Boolean   @default(false)

  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  tokens                UserToken[]
}

model UserToken {
  id          String      @id @default(uuid())
  token       String      @unique

  type        TokenType

  userId      String
  expiresAt   DateTime
  user        User        @relation(fields: [userId], references: [id])
  @@index([token])
  @@index([userId])
}

enum TokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
  REFRESH_TOKEN
}

enum AuthProvider {
  LOCAL
  GOOGLE
}